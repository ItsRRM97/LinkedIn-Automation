# Copy to ~/.zshrc or a local .env (never commit real values).
# Required for launchd / CLI scripts outside Cursor.

BUFFER_MCP_TOKEN=your_buffer_api_token
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Notion Content Library database ID (hex, no dashes)
# NOTION_CONTENT_LIBRARY_DB=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: LinkedIn member ID for Composio comment replies
# LINKEDIN_ACTOR_ID=xxxxxxxxxx

# Optional: zero-click feed engage via Cursor SDK
# CURSOR_API_KEY=your_cursor_api_key
