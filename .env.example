# Copy to ~/.zshrc or a local .env (never commit real values).
# Required for launchd / CLI scripts outside Cursor.

BUFFER_MCP_TOKEN=your_buffer_api_token
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional override — defaults to Content Library DB 753369dc15fb4b3c82dd9c88cb753c3c
# NOTION_CONTENT_LIBRARY_DB=753369dc15fb4b3c82dd9c88cb753c3c

# Optional: LinkedIn member ID for Composio comment replies
# LINKEDIN_ACTOR_ID=xxxxxxxxxx

# Optional: zero-click feed engage via Cursor SDK (legacy browser path)
# CURSOR_API_KEY=your_cursor_api_key

# Feed engage daemon (hands-off CLI) — Groq default (free tier)
# Get key: https://console.groq.com
# GROQ_API_KEY=gsk_...
# FEED_GROQ_MODEL=llama-3.3-70b-versatile
# Optional OpenRouter fallback: set llm.provider=openrouter in config.json
# OPENROUTER_API_KEY=sk-or-v1-...
# LINKEDIN_LI_AT=...     # linkedin.com cookie
# LINKEDIN_JSESSIONID=ajax:...  # linkedin.com cookie (quote if special chars)
# FEED_PERSONA=optional inline persona override
